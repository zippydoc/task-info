                "options": {
                  "standard": {
                    "label": "Standard"
                  },
                  "number": {
                    "label": "Number"
                  },
                  "percentage": {
                    "label": "Percentage"
                  },
                  "text": {
                    "label": "Text"
                  },
                  "date": {
                    "label": "Date"
                  },
                  "currency": {
                    "label": "Currency"
                  }
                },
                "val": "standard"
              },
              "format__rounding": {
                "type": "select",
                "label": "Decimal Places for display",
                "show_if": "this.format__category=='number' || this.format__category=='percentage' || this.format__category=='currency'",
                "required": true,
                "options": {
                  "no_rounding": {
                    "label": "No rounding"
                  },
                  "0": {
                    "label": "0 digits"
                  },
                  "1": {
                    "label": "1 digits"
                  },
                  "2": {
                    "label": "2 digits"
                  },
                  "3": {
                    "label": "3 digits"
                  },
                  "4": {
                    "label": "4 digits"
                  },
                  "5": {
                    "label": "5 digits"
                  },
                  "6": {
                    "label": "6 digits"
                  },
                  "7": {
                    "label": "7 digits"
                  },
                  "8": {
                    "label": "8 digits"
                  },
                  "9": {
                    "label": "9 digits"
                  }
                },
                "val": "2"
