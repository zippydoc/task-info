            "fields": {
              "field_name": {
                "type": "select",
                "label": "Select Column",
                "table": "target_table.table_id",
                "bind": "COLUMNS",
                "required": true
              },
              "order": {
                "type": "select",
                "label": "Order",
                "options": {
                  "-": {
                    "label": "-"
                  },
                  "asc": {
                    "label": "Asc"
                  },
                  "desc": {
                    "label": "Desc"
                  }
                },
                "val": "-"
