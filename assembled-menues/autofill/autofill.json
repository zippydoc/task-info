                "minLength": 1,
                "maxLength": 255,
                "label": "New Column Name",
                "style": "margin-left: 10px"
              },
              "delete": {
                "type": "button",
                "label": "Delete",
                "function": "DELETE_ROW"
              }
            },
            "breakLine": true
          },
          "output.table_name_type": {
            "type": "select",
            "label": "Table Name",
            "show_if": "output.output_as_new_table=='true'",
            "required": true,
            "options": {
              "task_name": {
                "label": "Task Name (Flow Name)"
              },
              "custom_name": {
                "label": "Custom Name"
              },
              "compose_name": {
                "label": "Compose Name"
              }
