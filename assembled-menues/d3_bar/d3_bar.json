{
  "description": "Generate a D3 Bar chart from your table",
  "image": "https://raw.githubusercontent.com/zippydoc/Pictograms/master/D3-Sunburst.gif",
  "scriptSettings": {
    "autoLoadTable": [],
    "countries": [
      "US",
      "UK"
    ],
    "languages": [
      "EN"
    ],
    "displayName": "D3 Bar chart",
    "payingUsersOnly": false,
    "explanationPicture": "",
    "type": "Create Reports",
    "attributes": [
      "1-input",
      "Guest-User",
      "Starter-Screen"
    ]
  },
  "menu": [
    {
      "input": {
        "type": "fieldset",
        "label": "Select Input Table",
        "style": "border-radius: 3px; border: 1px solid #ccc",
        "repeat": false,
        "fields": {
          "table_id": {
            "type": "select",
            "label": "Select Table",
            "bind": "TABLES",
            "empty": "",
            "required": true,
            "breakLine": true
          },
          "remove_input_table_after_processing": {
            "type": "hidden",
            "val": "false"
          },
          "is_word": {
            "type": "hidden",
            "val": "false"
          }
        }
      }
    },
    {
      "options_box": {
        "type": "fieldset",
        "label": "",
        "style": "border-radius: 3px; margin-right:5px; border: 1px solid #ccc",
        "repeat": false,
        "fields": {
          "options.chart_type": {
            "type": "hidden",
            "val": "bar_chart"
          },
          "options.configure_manual": {
            "type": "hidden",
            "val": "true"
          },
          "options.x_axis_col": {
            "type": "select",
            "label": "X-axis column",
            "table": "table_id",
            "bind": "COLUMNS",
            "required": true
          },
          "options.value_col": {
            "type": "select",
            "label": "Value column",
            "table": "table_id",
            "bind": "COLUMNS",
            "required": true
          }
        }
      }
    },
    {
      "options.popup_or_table": {
        "type": "select",
        "label": "Type",
        "required": true,
        "options": {
          "popup": {
            "label": "Pop-Up"
          },
          "embedded": {
            "label": "Embedded"
          }
        },
        "val": "popup",
        "breakLine": true
      }
    }
  ],
  "script": "https://api.github.com/repos/zippydoc/basic/contents/D3.py?ref=master",
  "version": 1.0
}
