        "fields": {
          "output.table_name_type": {
            "type": "select",
            "label": "Table Name",
            "required": true,
            "options": {
              "task_name": {
                "label": "Task Name (Flow Name)"
              },
              "custom_name": {
                "label": "Custom Name"
              },
              "compose_name": {
                "label": "Compose Name"
              }
            },
            "val": "task_name",
            "breakLine": true
          },
          "output.custom_text": {
            "type": "text",
            "label": "Output Table Name",
            "show_if": "output.table_name_type=='custom_name'",
