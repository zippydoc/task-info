            "style": "border-radius: 3px; border: 1px solid #ccc",
            "show_if": "output.table_name_type=='compose_name'",
            "repeat": false,
            "fields": {
              "output.prefix_rule": {
                "type": "select",
                "label": "Prefix",
                "val": "empty",
