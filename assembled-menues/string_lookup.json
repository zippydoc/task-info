                  },
                  "label": {
                    "type": "text",
                    "label": "Label",
                    "val": "positive10",
                    "required": true
                  },
                  "delete": {
                    "type": "button",
                    "label": "Delete",
                    "function": "DELETE_ROW"
                  }
