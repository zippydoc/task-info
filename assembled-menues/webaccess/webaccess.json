                  "date_string_type2": {
                    "label": "Date: yyyy_mm_dd"
                  },
                  "time_string": {
                    "label": "Time: h_min_sec"
                  },
                  "datetime_string": {
                    "label": "Date_Time"
                  },
                  "custom": {
                    "label": "Custom"
